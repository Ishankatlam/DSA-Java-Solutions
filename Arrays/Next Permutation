Next Permutation 

class Solution {
    public void nextPermutation(int[] nums) {
                int n= nums.length;
        if(n<2)return ;
        // finding pivot index 
        int pivot_index = -1;
        for(int i=n-2;i>=0;i--)
        {
            if(nums[i] < nums[i+1])
            {
                pivot_index = i;
                break;
            }
        }
        //  if pvot index mot found then sorting array 
        if(pivot_index==-1)
        {
            Arrays.sort(nums);
          return;
        }
        //  swapping 
        for(int j=n-1;j>=pivot_index;j--)
        {
            if(nums[j]>nums[pivot_index])
            {
                int temp = nums[pivot_index];
                nums[pivot_index] = nums[j];
                nums[j]  = temp ;
                break;
            }
        }
         int left = pivot_index+1;
         int right = n-1;
         while(left< right )
         {
             int temp = nums[left];
             nums[left]= nums[right];
             nums[right] = temp ;
             left++;
             right --;
         }
         return;
    }
}
Pattern Used 
Finding Pivot 
And Then Swapping 
