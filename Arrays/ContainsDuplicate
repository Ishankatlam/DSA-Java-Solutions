Contains Duplicate Chocolate
problem on the easier side 

class Solution {
    public boolean containsDuplicate(int[] nums) {
        if(nums.length==1)
        {
            return false ;
        }
        Arrays.sort(nums);
        for(int i=0;i<nums.length-1;i++)
        {
            if((nums[i] ^ nums[i+1])==0)
             {
                return true ;
             }
        }
        return false ;
    }

}
